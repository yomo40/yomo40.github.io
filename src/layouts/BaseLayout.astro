---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import { searchConfig, siteConfig } from "@/config/site";
import { withBase } from "@/utils/url";
import "@/styles/base.css";
import "@/styles/prose.css";

interface Props {
  title?: string;
  description?: string;
  heroTitle?: string;
  heroSubtitle?: string;
  showSidebar?: boolean;
  pageClass?: string;
}

const {
  title,
  description = siteConfig.description,
  heroTitle = siteConfig.heroTitle,
  heroSubtitle = siteConfig.heroSubtitle,
  showSidebar = true,
  pageClass = ""
} = Astro.props;

const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
const baseUrl = import.meta.env.BASE_URL;
const faviconHref = withBase("/pn.png");
const bannerBgUrl = withBase("/images/banner-bg.jpg");
const bannerBackgroundStyle = `--site-banner-image: url("${bannerBgUrl}")`;
const pagefindHighlightScriptSrc = withBase("/pagefind/pagefind-highlight.js");
const searchHighlightParam = searchConfig.highlightParam;
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href={faviconHref} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const key = "yomo-theme";
        const root = document.documentElement;
        const stored = localStorage.getItem(key);
        const theme =
          stored ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        root.setAttribute("data-theme", theme);
      })();
    </script>
    <script is:inline define:vars={{ baseUrl }}>
      (() => {
        if (baseUrl === "/") return;
        const normalizedBase = baseUrl.endsWith("/")
          ? baseUrl.slice(0, -1)
          : baseUrl;

        const withBase = (value) => {
          if (!value || !value.startsWith("/") || value.startsWith("//")) {
            return value;
          }
          if (value.startsWith(normalizedBase + "/") || value === normalizedBase) {
            return value;
          }
          return normalizedBase + value;
        };

        document.addEventListener("DOMContentLoaded", () => {
          document.querySelectorAll("a[href^='/']").forEach((anchor) => {
            const href = anchor.getAttribute("href");
            if (!href) return;
            anchor.setAttribute("href", withBase(href));
          });

          document.querySelectorAll("img[src^='/']").forEach((image) => {
            const src = image.getAttribute("src");
            if (!src) return;
            image.setAttribute("src", withBase(src));
          });

          document
            .querySelectorAll("link[rel='icon'][href^='/']")
            .forEach((iconLink) => {
              const href = iconLink.getAttribute("href");
              if (!href) return;
              iconLink.setAttribute("href", withBase(href));
            });
        });
      })();
    </script>
  </head>
  <body
    class={`page-enter ${pageClass}`.trim()}
    style={bannerBackgroundStyle}
  >
    <div class="banner-layer" aria-hidden="true"></div>
    <Header />

    <section class="hero-banner">
      <div class="hero-banner__content">
        <p class="hero-kicker">yomo40のblog</p>
        <h1>{heroTitle}</h1>
        <p>{heroSubtitle}</p>
      </div>
    </section>

    <div class={`content-grid ${showSidebar ? "" : "content-grid--wide"}`}>
      {showSidebar && <Sidebar />}
      <main class="main-pane">
        <slot />
      </main>
    </div>

    <Footer />

    <script is:inline>
      (() => {
        const mount = () => {
          requestAnimationFrame(() => {
            document.body.classList.add("page-ready");
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", mount, { once: true });
        } else {
          mount();
        }
      })();
    </script>
    <script
      is:inline
      define:vars={{ pagefindHighlightScriptSrc, searchHighlightParam }}
    >
      (() => {
        const query = new URLSearchParams(window.location.search);
        if (!query.has(searchHighlightParam)) return;

        const loadPagefindHighlight = () =>
          new Promise((resolve, reject) => {
            if (window.PagefindHighlight) {
              resolve(window.PagefindHighlight);
              return;
            }

            const existing = document.querySelector(
              "script[data-pagefind-highlight='true']"
            );
            if (existing) {
              existing.addEventListener(
                "load",
                () => resolve(window.PagefindHighlight),
                { once: true }
              );
              existing.addEventListener(
                "error",
                () => reject(new Error("Pagefind highlight script load failed")),
                { once: true }
              );
              return;
            }

            const script = document.createElement("script");
            script.src = pagefindHighlightScriptSrc;
            script.async = true;
            script.dataset.pagefindHighlight = "true";
            script.onload = () => resolve(window.PagefindHighlight);
            script.onerror = () =>
              reject(
                new Error(
                  `Failed to load highlight script: ${pagefindHighlightScriptSrc}`
                )
              );
            document.head.appendChild(script);
          });

        loadPagefindHighlight()
          .then((PagefindHighlight) => {
            if (!PagefindHighlight) return;
            new PagefindHighlight({
              highlightParam: searchHighlightParam
            });
          })
          .catch((error) => {
            console.error("[pagefind] highlight bootstrap failed:", error);
          });
      })();
    </script>
  </body>
</html>
