---
interface Props {
  username: string;
  commitLimit?: number;
  prLimit?: number;
}

const { username, commitLimit = 5, prLimit = 5 } = Astro.props;
const normalizedId =
  username.replace(/[^a-zA-Z0-9_-]/g, "").toLowerCase() || "user";
const componentId = `github-pulse-${normalizedId}`;
---

<section
  id={componentId}
  class="github-pulse"
  data-username={username}
  data-commit-limit={String(commitLimit)}
  data-pr-limit={String(prLimit)}
>
  <div class="github-pulse__head">
    <h3>GitHub 开发动态</h3>
    <p>@{username} · 我在 GitHub 上又提交了什么？</p>
  </div>

  <div class="github-pulse__columns">
    <article class="activity-panel">
      <h4>最近 Commit</h4>
      <ul class="activity-list" data-commits></ul>
      <p class="activity-empty" data-commits-empty>正在加载...</p>
    </article>

    <article class="activity-panel">
      <h4>已合并 PR</h4>
      <ul class="activity-list" data-prs></ul>
      <p class="activity-empty" data-prs-empty>正在加载...</p>
    </article>
  </div>

  <p class="github-pulse__note">
    数据来源：GitHub Public API（公开仓库）。若触发限流，稍后刷新即可。
  </p>
</section>

<script is:inline define:vars={{ componentId }}>
  (() => {
    const root = document.getElementById(componentId);
    if (!root || root.dataset.ready === "true") return;
    root.dataset.ready = "true";

    const username = root.dataset.username || "";
    const commitLimit = Number(root.dataset.commitLimit || "5");
    const prLimit = Number(root.dataset.prLimit || "5");

    const commitList = root.querySelector("[data-commits]");
    const prList = root.querySelector("[data-prs]");
    const commitEmpty = root.querySelector("[data-commits-empty]");
    const prEmpty = root.querySelector("[data-prs-empty]");

    if (!commitList || !prList || !commitEmpty || !prEmpty) return;

    const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit"
    });

    function formatDate(value) {
      const date = new Date(value || "");
      if (Number.isNaN(date.getTime())) return "日期未知";
      return dateFormatter.format(date);
    }

    function parseRepoFromPrUrl(url) {
      const match = /github\.com\/([^/]+\/[^/]+)\/pull\//.exec(url || "");
      return match ? match[1] : "未知仓库";
    }

    async function requestJSON(url) {
      const response = await fetch(url, {
        headers: {
          Accept: "application/vnd.github+json"
        }
      });

      if (!response.ok) {
        throw new Error(`Request failed: ${response.status}`);
      }

      return response.json();
    }

    function clearList(node) {
      node.textContent = "";
    }

    function renderItems(listNode, emptyNode, items, emptyText) {
      clearList(listNode);

      if (!items.length) {
        emptyNode.hidden = false;
        emptyNode.textContent = emptyText;
        return;
      }

      emptyNode.hidden = true;

      items.forEach((item) => {
        const li = document.createElement("li");
        li.className = "activity-item";

        const link = document.createElement("a");
        link.href = item.url;
        link.target = "_blank";
        link.rel = "noreferrer";
        link.textContent = item.title;

        const meta = document.createElement("small");
        meta.textContent = item.meta;

        li.append(link, meta);
        listNode.append(li);
      });
    }

    async function fetchRecentCommitsFromEvents() {
      const events = await requestJSON(
        `https://api.github.com/users/${encodeURIComponent(
          username
        )}/events/public?per_page=100`
      );
      const commits = [];

      for (const event of events) {
        if (event?.type !== "PushEvent") continue;

        const repo = event?.repo?.name || "未知仓库";
        const createdAt = event?.created_at;
        const eventCommits = Array.isArray(event?.payload?.commits)
          ? event.payload.commits
          : [];

        for (const commit of eventCommits) {
          if (!commit?.sha) continue;

          const message = (commit.message || "无提交说明")
            .split("\n")[0]
            .trim();

          commits.push({
            title: message || "无提交说明",
            url: `https://github.com/${repo}/commit/${commit.sha}`,
            meta: `${repo} · ${String(commit.sha).slice(0, 7)} · ${formatDate(
              createdAt
            )}`
          });

          if (commits.length >= commitLimit) {
            return commits;
          }
        }
      }

      return commits;
    }

    async function fetchRecentCommitsFromSearch() {
      const query = encodeURIComponent(`author:${username}`);
      const data = await requestJSON(
        `https://api.github.com/search/commits?q=${query}&sort=author-date&order=desc&per_page=${Math.max(
          commitLimit * 2,
          10
        )}`
      );

      const items = Array.isArray(data?.items) ? data.items : [];

      return items
        .map((item) => {
          const sha = String(item?.sha || "");
          if (!sha) return null;

          const message = String(item?.commit?.message || "无提交说明")
            .split("\n")[0]
            .trim();
          const repo = item?.repository?.full_name || "未知仓库";
          const date = item?.commit?.author?.date || item?.commit?.committer?.date;

          return {
            title: message || "无提交说明",
            url: item?.html_url || `https://github.com/${repo}/commit/${sha}`,
            meta: `${repo} · ${sha.slice(0, 7)} · ${formatDate(date)}`
          };
        })
        .filter(Boolean);
    }

    async function fetchRecentCommits() {
      let eventsFailed = false;
      const eventsCommits = await fetchRecentCommitsFromEvents().catch(() => {
        eventsFailed = true;
        return [];
      });

      if (eventsCommits.length >= commitLimit) {
        return eventsCommits.slice(0, commitLimit);
      }

      let searchFailed = false;
      const searchCommits = await fetchRecentCommitsFromSearch().catch(() => {
        searchFailed = true;
        return [];
      });
      const merged = [...eventsCommits];
      const seen = new Set(merged.map((item) => item.url));

      searchCommits.forEach((item) => {
        if (seen.has(item.url)) return;
        seen.add(item.url);
        merged.push(item);
      });

      if (!merged.length && eventsFailed && searchFailed) {
        throw new Error("Both commit data sources failed");
      }

      return merged.slice(0, commitLimit);
    }

    async function fetchMergedPRs() {
      const query = encodeURIComponent(`author:${username} is:pr is:merged`);
      const data = await requestJSON(
        `https://api.github.com/search/issues?q=${query}&sort=updated&order=desc&per_page=${prLimit}`
      );

      const items = Array.isArray(data?.items) ? data.items : [];

      return items.slice(0, prLimit).map((item) => ({
        title: item.title || "无标题 PR",
        url: item.html_url,
        meta: `${parseRepoFromPrUrl(item.html_url)} · 合并于 ${formatDate(
          item.closed_at || item.updated_at
        )}`
      }));
    }

    if (!username) {
      commitEmpty.textContent = "未配置 GitHub 用户名。";
      prEmpty.textContent = "未配置 GitHub 用户名。";
      return;
    }

    Promise.allSettled([fetchRecentCommits(), fetchMergedPRs()]).then(
      ([commitResult, prResult]) => {
        if (commitResult.status === "fulfilled") {
          renderItems(
            commitList,
            commitEmpty,
            commitResult.value,
            "暂无最近公开提交记录。"
          );
        } else {
          commitEmpty.hidden = false;
          commitEmpty.textContent = "提交记录加载失败，请稍后刷新。";
        }

        if (prResult.status === "fulfilled") {
          renderItems(
            prList,
            prEmpty,
            prResult.value,
            "暂无最近已合并 PR。"
          );
        } else {
          prEmpty.hidden = false;
          prEmpty.textContent = "PR 记录加载失败，请稍后刷新。";
        }
      }
    );
  })();
</script>
