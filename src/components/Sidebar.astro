---
import NeteaseRandomTrack from "@/components/NeteaseRandomTrack.astro";
import { collectionMeta, siteConfig, socialLinks } from "@/config/site";
import { withBase } from "@/utils/url";
import { getSidebarData } from "@/utils/content";
import { formatDate } from "@/utils/date";

const { recentPosts, categories } = await getSidebarData();
---

<aside class="sidebar-stack" aria-label="侧边栏">
  <section class="card profile-card">
    <img
      class="profile-avatar"
      src={withBase("/images/avatar.jpg")}
      alt="yomo40 avatar"
      width="260"
      height="260"
      loading="lazy"
    />
    <h2>yomo40</h2>
    <p>May the world treat you gently.</p>
    <div class="profile-actions">
      {socialLinks.map((item) => (
        <a href={item.href} target="_blank" rel="noreferrer">
          {item.label}
        </a>
      ))}
    </div>
  </section>

  <section class="card widget-card">
    <h3>胡言乱语</h3>
    <ul class="term-list">
      {Object.entries(collectionMeta).map(([key, meta]) => (
        <li>
          <a href={withBase(`/${key}/`)}>{meta.label}</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="card widget-card">
    <h3>分类</h3>
    {
      categories.length ? (
        <ul class="term-list">
          {categories.map((item) => (
            <li>
              <a href={withBase(`/categories/${item.slug}/`)}>{item.name}</a>
              <span>{item.count}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="widget-empty">暂无分类数据</p>
      )
    }
  </section>

  <section class="card widget-card">
    <h3>我的品味</h3>
    <NeteaseRandomTrack
      playlistId={siteConfig.neteasePlaylistId}
      playlistUrl={siteConfig.neteasePlaylistUrl}
    />
  </section>

  <section class="card widget-card">
    <h3>最近更新</h3>
    {
      recentPosts.length ? (
        <ul class="recent-list">
          {recentPosts.map((post) => (
            <li>
              <a href={withBase(post.permalink)}>{post.entry.data.title}</a>
              <time datetime={post.entry.data.date.toISOString()}>
                {formatDate(post.entry.data.date)}
              </time>
            </li>
          ))}
        </ul>
      ) : (
        <p class="widget-empty">暂无文章</p>
      )
    }
  </section>
</aside>
