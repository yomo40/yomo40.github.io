---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { navLinks } from "@/config/site";
import { withBase } from "@/utils/url";

const baseUrl = import.meta.env.BASE_URL;
const rawPath = Astro.url.pathname;
let pathname = rawPath;
const normalizedBase =
  baseUrl.endsWith("/") && baseUrl !== "/" ? baseUrl.slice(0, -1) : baseUrl;

if (normalizedBase !== "/" && rawPath.startsWith(normalizedBase)) {
  pathname = rawPath.slice(normalizedBase.length);
}

if (!pathname.startsWith("/")) {
  pathname = `/${pathname}`;
}

if (pathname === "") {
  pathname = "/";
}

function isActive(href: string) {
  if (href === "/") {
    return pathname === "/";
  }
  return pathname.startsWith(href);
}

const brandHref = withBase("/");
const rssHref = withBase("/rss.xml");
---

<header class="top-shell">
  <div class="nav-card">
    <a class="brand" href={brandHref}>
      <span class="brand-dot"></span>
      <span class="brand-text">yomo40のblog</span>
    </a>

    <nav class="main-nav" aria-label="主导航">
      {navLinks.map((item) => (
        <a
          href={withBase(item.href)}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="nav-tools">
      <a href={rssHref} class="tool-link" aria-label="RSS 订阅">
        RSS
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
