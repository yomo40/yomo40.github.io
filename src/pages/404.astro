---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/utils/url";
---

<BaseLayout
  title="404"
  heroTitle="页面未找到"
  heroSubtitle="链接可能已变更，返回首页继续阅读。"
  showSidebar={false}
>
  <section class="card page-title-card not-found-card">
    <h2>404</h2>
    <p>这个页面不存在或链接已失效。</p>
    <a class="cta-link" href={withBase("/")}>返回首页</a>
  </section>
</BaseLayout>
